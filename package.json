{
  "name": "unbunked-news",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Stephane Wetterwald",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev -p ${APP_PORT:-3030}",
    "build": "next build",
    "build:scripts": "esbuild src/db/migrate.ts src/db/seed-admin.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist/scripts --out-extension:.js=.cjs",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "tsx src/db/seed-admin.ts",
    "db:seed-articles": "tsx src/db/seed-articles.ts",
    "db:clean-articles": "tsx src/db/clean-articles.ts",
    "db:rescore-local": "node --conditions=react-server --env-file=.env --import tsx src/db/rescore-articles.local.ts",
    "db:backfill-scoring-local": "node --env-file=.env --import tsx src/db/backfill-scoring.local.ts",
    "db:backfill-rubrics-local": "node --env-file=.env --import tsx src/db/backfill-rubrics.local.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@extractus/article-extractor": "^8.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "postgres": "^3.4.9",
    "puppeteer-core": "^25.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "undici": "^8.4.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
