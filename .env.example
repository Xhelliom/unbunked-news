# Postgres connection — used by the Next.js app and by Drizzle Kit.
# Local dev matches the credentials in docker-compose.yml.
DATABASE_URL=postgresql://unbunked:unbunked@localhost:5432/unbunked

# Claude API for the fact-checking pipeline — added in a later step.
# ANTHROPIC_API_KEY=

# BetterAuth (admin sessions). Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-a-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Used once by `pnpm db:seed-admin` to create the first admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
