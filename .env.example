# Host ports — let the docker stack coexist with other running containers.
# docker compose reads these automatically. `pnpm dev` defaults to APP_PORT's
# value below; override per-run with: APP_PORT=3022 pnpm dev
APP_PORT=3030
DB_PORT=5434
ADMINER_PORT=8090

# Postgres connection — used by the Next.js app and by Drizzle Kit.
# Host/port must match DB_PORT above (the DB runs in docker, the app on host).
DATABASE_URL=postgresql://unbunked:unbunked@localhost:5434/unbunked

# Optional: max connections in this process's Postgres pool (defaults to 10).
# With N web replicas, DATABASE_POOL_MAX * N must stay below Postgres
# max_connections — cap it (or front the DB with PgBouncer) before scaling out.
# DATABASE_POOL_MAX=10

# Selects what this process does (defaults to hybrid when unset):
#   web    — serves HTTP only; does NOT drain the job queue.
#   worker — drains the job queue only; not behind the web Service/Ingress.
#   hybrid — serves HTTP and drains the queue in the same process.
# APP_ROLE=hybrid

# Claude API for the fact-checking pipeline.
ANTHROPIC_API_KEY=

# Optional external evidence for the scoring pipeline (docs/SCORING.md §6).
# When unset, the corresponding signal stays "unknown" (never invented) and the
# pipeline degrades gracefully — only confidence drops.
#
# Functional today: feeds the `corroboration` criterion and arms the
# `centralClaimDebunked` killswitch via the Google Fact Check Tools API
# (ClaimReview). Create a key in Google Cloud with "Fact Check Tools API" enabled.
# GOOGLE_FACTCHECK_API_KEY=
#
# Reserved — connectors NOT wired yet (stubs in src/lib/pipeline/data-sources.ts,
# TODO #scoring-connectors). Setting these has no effect until implemented, so
# the `domainImpersonation` killswitch cannot currently fire.
# UNRELIABLE_DOMAINS_URL=
# WHOIS_API_URL=

# Optional: path to a Chromium binary for the Puppeteer scraping fallback.
# In the Docker image this is set to /usr/bin/chromium-browser automatically.
# CHROMIUM_PATH=/usr/bin/chromium-browser

# BetterAuth (admin sessions). Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-a-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3030

# Optional salt for the privacy-first analytics visitor hash. Falls back to
# BETTER_AUTH_SECRET when unset. Generate with: openssl rand -base64 32
# ANALYTICS_SALT=

# Used by `pnpm db:seed-admin "email@domain.tld" ["password"] [--reset-password]`.
# ADMIN_EMAIL and ADMIN_PASSWORD are optional fallbacks for legacy usage.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
