# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
# bundled one-off entrypoints (generated at image build time)
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# npm lockfile — this project uses pnpm (pnpm-lock.yaml is the source of truth)
package-lock.json

# env files (can opt-in for committing if needed)
.env*
!.env.example

# kubernetes secrets (never commit real values)
/k8s/secret.yaml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local design-handoff bundle (reference only)
claude-design

# local skills installed via `npx skills add` — never commit
.agents/
.claude/skills/
.claude/settings.local.json
skills-lock.json

# Visual brainstorming companion
.superpowers/
